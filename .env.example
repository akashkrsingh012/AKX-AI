# AKX AI Environment Variables
# Copy relevant sections to each service's .env file

# ── Frontend (frontend/.env) ──
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=1:xxx:web:xxx
VITE_SERVER_URL=
VITE_GATEWAY_URL=http://localhost:8000
VITE_RAZORPAY_KEY=your-razorpay-key-id

# ── Gateway (backend/gateway/.env) ──
PORT=8000
FRONTEND_URL=http://localhost:3000
REDIS_URL=redis://localhost:6379
AUTH_SERVICE=http://localhost:8001
CHAT_SERVICE=http://localhost:8002
AGENT_SERVICE=http://localhost:8003
BILLING_SERVICE=http://localhost:8004

# Production gateway (npm run start):
# NODE_ENV=production
# PORT=3000

# ── Auth (backend/services/auth/.env) ──
# PORT=8001
# MONGODB_URL=mongodb://localhost:27017/cortex-ai
# FRONTEND_URL=http://localhost:3000

# ── Chat (backend/services/chat/.env) ──
# PORT=8002
# MONGODB_URL=mongodb://localhost:27017/cortex-ai

# ── Agent (backend/services/agent/.env) ──
# PORT=8003
# MONGODB_URL=mongodb://localhost:27017/cortex-ai
#
# Primary — Claude AI (Anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-20250514
#
# Alternatives (optional — set ONE valid key)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
# GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_API_KEY=your-openrouter-api-key
# GOOGLE_API_KEY=your-google-api-key
# GEMINI_API_KEY=your-gemini-api-key
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
#
# GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_MODEL=openai/gpt-4o-mini
# GOOGLE_API_KEY=
# CHAT_SERVICE=http://localhost:8002
# AUTH_SERVICE=http://localhost:8001
# GATEWAY_URL=http://localhost:3000
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# AWS_BUCKET_NAME=
# QDRANT_URL=
# QDRANT_API_KEY=

# ── Billing (backend/services/billing/.env) ──
# PORT=8004
# MONGODB_URL=mongodb://localhost:27017/cortex-ai
# AUTH_SERVICE=http://localhost:8001
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# ── Optional: Redis (docker compose up -d in backend/) ──
# Redis is optional in development — in-memory fallback is used when unavailable.
