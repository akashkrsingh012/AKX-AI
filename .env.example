# AKX AI Environment Variables
# Copy relevant sections to each service's .env file

# ── Frontend (frontend/.env) ──
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=1:xxx:web:xxx
VITE_SERVER_URL=https://your-render-backend-url.onrender.com
VITE_RAZORPAY_KEY=your-razorpay-key-id

# ── Unified Server (backend/services/auth/.env) ──
# This is the single server that runs ALL services (auth + chat + agent + billing).
# Set PORT to match your Render web service port (Render sets $PORT automatically).
PORT=8001
MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/cortex-ai
FRONTEND_URL=https://your-render-frontend-url.onrender.com
JWT_SECRET=your-super-secret-jwt-key

# ── AI Provider (set at least one) ──
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Or Groq:
# GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile

# Or OpenRouter:
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Razorpay (billing) ──
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ── Firebase (auth) ──
# (serviceAccount.json is needed too — see backend/services/auth/serviceAccount.json)

# ── AWS S3 (optional — agent uploads) ──
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# AWS_BUCKET_NAME=

# ── Qdrant (optional — vector search) ──
# QDRANT_URL=
# QDRANT_API_KEY=

# ── Tavily (optional — web search) ──
# TAVILY_API_KEY=

# ── Optional: Redis ──
# Redis is optional — in-memory fallback is used when unavailable.
# REDIS_URL=redis://localhost:6379
